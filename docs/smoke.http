@baseUrl = http://localhost:8080
@keycloakUrl = http://localhost:8082
@realm = organization-bookings
@publicClientId = bookings-public-client
@orgId = 11111111-1111-1111-1111-111111111111
@runId = {{$timestamp}}
@ownerEmail = owner_{{runId}}@test.local
@inviteeEmail = invitee_{{runId}}@test.local
@ownerPassword = Pass123!
@inviteePassword = Pass123!
@expiresAt = 2030-01-01T00:00:00Z
@customRoleCode1 = TEAM_LEAD_{{runId}}
@customRoleCode2 = TEAM_MANAGER_{{runId}}

### 01. Register owner user
POST {{baseUrl}}/api/users/register
Content-Type: application/json

{
  "email": "{{ownerEmail}}",
  "password": "{{ownerPassword}}",
  "firstName": "Owner",
  "lastName": "User",
  "patronymic": "Smoke"
}
> {%
client.test("Register owner: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
client.global.set("ownerUserId", response.body.userId);
client.global.set("ownerIdentityId", response.body.identityId);
%}

### 02. Get owner token from Keycloak
POST {{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token
Content-Type: application/x-www-form-urlencoded

grant_type=password&client_id={{publicClientId}}&username={{ownerEmail}}&password={{ownerPassword}}
> {%
client.test("Owner token: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
client.global.set("ownerAccessToken", response.body.access_token);
client.global.set("ownerRefreshToken", response.body.refresh_token);
%}

### 03. Internal: create organization owner
POST {{baseUrl}}/api/internal/organizations/owner
Content-Type: application/json

{
  "organizationId": "{{orgId}}",
  "ownerIdentityId": "{{ownerIdentityId}}"
}
> {%
client.test("Create owner: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
%}

### 04. Internal: check permission
POST {{baseUrl}}/api/internal/authorization/check
Content-Type: application/json

{
  "organizationId": "{{orgId}}",
  "identityId": "{{ownerIdentityId}}",
  "permissionCode": "ROLES_LIST"
}
> {%
client.test("Permission check: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
client.test("Permission check: allowed=true", function () {
  client.assert(response.body.allowed === true, "Expected allowed=true");
});
%}

### 05. Internal: user by identity
GET {{baseUrl}}/api/internal/users/by-identity/{{ownerIdentityId}}

> {%
client.test("Internal user by identity: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
%}

