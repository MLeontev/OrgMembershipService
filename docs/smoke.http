  client.assert(response.status === 200, "Expected 200");
});
client.global.set("inviteeAccessToken", response.body.access_token);
client.global.set("inviteeRefreshToken", response.body.refresh_token);
%}

### 19. Public: create invitation (for accept flow)
POST {{baseUrl}}/api/organizations/{{orgId}}/invitations
Authorization: Bearer {{ownerAccessToken}}
Content-Type: application/json

{
  "roleCodes": ["EMPLOYEE"],
  "expiresAt": "{{expiresAt}}"
}
> {%
client.test("Create invitation #1: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
client.global.set("invitationId1", response.body.invitationId);
client.global.set("invitationToken1", response.body.invitationToken);
%}

