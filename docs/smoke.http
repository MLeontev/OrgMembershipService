### 14. Public: create custom role
POST {{baseUrl}}/api/organizations/{{orgId}}/roles/custom
Authorization: Bearer {{ownerAccessToken}}
Content-Type: application/json

{
  "code": "{{customRoleCode1}}",
  "name": "Team Lead",
  "description": "Custom role for smoke test",
  "permissionCodes": ["MEMBERS_LIST", "MEMBERS_READ"]
}
> {%
client.test("Create custom role: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
client.global.set("customRoleId", response.body.roleId);
%}

### 15. Public: update custom role
PUT {{baseUrl}}/api/organizations/{{orgId}}/roles/custom/{{customRoleId}}
Authorization: Bearer {{ownerAccessToken}}
Content-Type: application/json

{
  "code": "{{customRoleCode2}}",
  "name": "Team Manager",
  "description": "Updated in smoke test",
  "permissionCodes": ["MEMBERS_LIST", "MEMBERS_READ", "MEMBERS_UPDATE"]
}
> {%
client.test("Update custom role: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
%}

### 16. Public: delete custom role
DELETE {{baseUrl}}/api/organizations/{{orgId}}/roles/custom/{{customRoleId}}
Authorization: Bearer {{ownerAccessToken}}

> {%
client.test("Delete custom role: 200", function () {
  client.assert(response.status === 200, "Expected 200");
});
%}

### 17. Register invitee user
POST {{baseUrl}}/api/users/register
Content-Type: application/json

{
  "email": "{{inviteeEmail}}",
  "password": "{{inviteePassword}}",
  "firstName": "Invitee",
  "lastName": "User",
  "patronymic": "Smoke"
}
> {%
